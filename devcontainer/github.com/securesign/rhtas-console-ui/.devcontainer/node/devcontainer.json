{
  "name": "rhtas-console-ui",
  "dockerComposeFile": "./docker-compose.yml",
  "service": "rhtas-console-ui",
  "workspaceFolder": "/workspace",
  "initializeCommand": "bash ${localEnv:DEVTOOLS_TSD_UI_PATH:~/git/devtools}/devcontainer/github.com/securesign/rhtas-console-ui/.devcontainer/node/initializeCommand.sh ${devcontainerId}",
  "postCreateCommand": "bash /tmp/postCreateCommand.sh ${devcontainerId}",
  "forwardPorts": [
    3000
  ],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "eamodio.gitlens",
        "dsznajder.es7-react-js-snippets",
        "esbenp.prettier-vscode",
        "vitest.explorer"
      ],
      "settings": {
        "git.alwaysSignOff": true
      }
    }
  }
}
